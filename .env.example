# Firebase / Google Cloud
GCP_PROJECT=fina-au
GOOGLE_CLOUD_PROJECT=fina-au
GOOGLE_CLOUD_QUOTA_PROJECT=fina-au

# Google Maps Geocoding API
GOOGLE_MAPS_API_KEY=xxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Gemini API
# Provide this as a secret in deployed Cloud Functions, not in source control.
GEMINI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# SMTP Email Configuration
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=xxxxxxxxxxxxxx
SMTP_PASSWORD=xxxxxxxxxxxxxxxx